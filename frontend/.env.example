# =====================================================
# XenoPulse Frontend — Environment Variables
# =====================================================
# Copy this file to .env.local for local development
# Set these in your Vercel project settings for production

# Backend API URL (Railway deployment URL)
# Example: https://xenopulse-backend.up.railway.app
VITE_API_URL=https://your-backend.up.railway.app

# Also supported (legacy):
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
